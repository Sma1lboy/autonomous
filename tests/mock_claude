#!/usr/bin/env bash
# mock_claude — Fake claude CLI for integration tests.
# Outputs stream-json format matching real CC output.
#
# Control via env vars:
#   MOCK_CLAUDE_COST    — cost to report (default: 0.10)
#   MOCK_CLAUDE_COMMIT  — if "1", create a git commit in MOCK_CLAUDE_REPO
#   MOCK_CLAUDE_EXIT    — exit code (default: 0)
#   MOCK_CLAUDE_DELAY   — sleep N seconds before output (default: 0)
#   MOCK_CLAUDE_REPO    — git repo path for commits (required if COMMIT=1)
#   MOCK_CLAUDE_MSG     — commit message (default: "mock: test change")
set -uo pipefail

COST="${MOCK_CLAUDE_COST:-0.10}"
DO_COMMIT="${MOCK_CLAUDE_COMMIT:-0}"
EXIT_CODE="${MOCK_CLAUDE_EXIT:-0}"
DELAY="${MOCK_CLAUDE_DELAY:-0}"
REPO="${MOCK_CLAUDE_REPO:-.}"
MSG="${MOCK_CLAUDE_MSG:-mock: test change}"

if [ "$DELAY" -gt 0 ] 2>/dev/null; then
  sleep "$DELAY"
fi

# Simulate a tool call (assistant message)
cat << EOF
{"type":"assistant","message":{"content":[{"type":"tool_use","name":"Read","id":"mock-1"}]}}
EOF

# If commit requested, make a change and commit
if [ "$DO_COMMIT" = "1" ] && git -C "$REPO" rev-parse --git-dir >/dev/null 2>&1; then
  echo "mock-change-$(date +%s)" >> "$REPO/.mock-changes"
  git -C "$REPO" add .mock-changes 2>/dev/null
  git -C "$REPO" commit -m "$MSG" --no-gpg-sign 2>/dev/null >&2 || true
fi

# Output result line
cat << EOF
{"type":"result","result":"Task completed.","total_cost_usd":$COST,"session_id":"mock-session","model":"mock","duration_ms":1000,"duration_api_ms":800,"num_turns":1}
EOF

exit "$EXIT_CODE"
